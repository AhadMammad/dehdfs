# Shared Hadoop configuration for Lab 12 — rack awareness.

# --- core-site.xml ---
CORE_CONF_fs_defaultFS=hdfs://namenode:9000
CORE_CONF_hadoop_http_staticuser_user=root
# The NameNode runs this script to map each DataNode's IP to a rack path.
CORE_CONF_net_topology_script_file_name=/etc/hadoop/topology.sh

# --- hdfs-site.xml ---
# 3 replicas across 2 racks so we can see rack-aware placement.
HDFS_CONF_dfs_replication=3
HDFS_CONF_dfs_permissions_enabled=false
HDFS_CONF_dfs_namenode_datanode_registration_ip___hostname___check=false
HDFS_CONF_dfs_webhdfs_enabled=true
