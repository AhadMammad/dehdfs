<?xml version="1.0" encoding="UTF-8"?>
<?xml-stylesheet type="text/xsl" href="configuration.xsl"?>
<!-- Lab 6 HA core-site.xml. fs.defaultFS points at the logical NAMESERVICE, not a single host. -->
<configuration>
  <property>
    <name>fs.defaultFS</name>
    <value>hdfs://mycluster</value>
  </property>
  <!-- ZooKeeper ensemble used by the ZKFC failover controllers to elect the active NameNode. -->
  <property>
    <name>ha.zookeeper.quorum</name>
    <value>zookeeper:2181</value>
  </property>
  <property>
    <name>hadoop.http.staticuser.user</name>
    <value>root</value>
  </property>
</configuration>
