# Shared Hadoop configuration for Lab 1 (bde2020 images read these env vars and
# turn them into core-site.xml / hdfs-site.xml entries).

# --- core-site.xml ---
CORE_CONF_fs_defaultFS=hdfs://namenode:9000
CORE_CONF_hadoop_http_staticuser_user=root

# --- hdfs-site.xml ---
# Single DataNode in this lab, so replicate each block exactly once.
HDFS_CONF_dfs_replication=1
# Turn off permission checks so the demo can write anywhere without a Kerberos/user setup.
HDFS_CONF_dfs_permissions_enabled=false
# Let containers register by hostname (they share a user-defined Docker network).
HDFS_CONF_dfs_namenode_datanode_registration_ip___hostname___check=false
HDFS_CONF_dfs_webhdfs_enabled=true
