# Shared Hadoop configuration for Lab 11 — permissions & ACLs.

# --- core-site.xml ---
CORE_CONF_fs_defaultFS=hdfs://namenode:9000
CORE_CONF_hadoop_http_staticuser_user=root

# --- hdfs-site.xml ---
HDFS_CONF_dfs_replication=1
# Unlike the other labs, this one turns permission CHECKS ON so denials actually happen...
HDFS_CONF_dfs_permissions_enabled=true
# ...and enables extended ACLs (setfacl/getfacl).
HDFS_CONF_dfs_namenode_acls_enabled=true
HDFS_CONF_dfs_namenode_datanode_registration_ip___hostname___check=false
HDFS_CONF_dfs_webhdfs_enabled=true
