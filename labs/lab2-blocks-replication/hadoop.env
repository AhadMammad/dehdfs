# Shared Hadoop configuration for Lab 2 — blocks & replication.

# --- core-site.xml ---
CORE_CONF_fs_defaultFS=hdfs://namenode:9000
CORE_CONF_hadoop_http_staticuser_user=root

# --- hdfs-site.xml ---
# Three DataNodes in this lab, so replicate every block three times (the HDFS default).
HDFS_CONF_dfs_replication=3
# Small 1 MiB blocks so a small demo file visibly splits into MANY blocks.
# (Production default is 128 MiB; we shrink it purely to make block-splitting observable.)
HDFS_CONF_dfs_blocksize=1048576
HDFS_CONF_dfs_permissions_enabled=false
HDFS_CONF_dfs_namenode_datanode_registration_ip___hostname___check=false
HDFS_CONF_dfs_webhdfs_enabled=true
