# Shared Hadoop configuration for Lab 3 — DataNode failure & recovery.

# --- core-site.xml ---
CORE_CONF_fs_defaultFS=hdfs://namenode:9000
CORE_CONF_hadoop_http_staticuser_user=root

# --- hdfs-site.xml ---
HDFS_CONF_dfs_replication=3
HDFS_CONF_dfs_blocksize=1048576
HDFS_CONF_dfs_permissions_enabled=false
HDFS_CONF_dfs_namenode_datanode_registration_ip___hostname___check=false
HDFS_CONF_dfs_webhdfs_enabled=true

# --- Speed up dead-node detection so the lab is watchable ---
# DataNodes send a heartbeat every 3s. The NameNode rechecks for stale nodes every
# 15s. A node is declared DEAD after 2*recheck + 10*heartbeat = 2*15 + 10*3 = ~60s.
# (Production defaults declare a node dead after ~10.5 minutes.)
HDFS_CONF_dfs_heartbeat_interval=3
HDFS_CONF_dfs_namenode_heartbeat_recheck___interval=15000
