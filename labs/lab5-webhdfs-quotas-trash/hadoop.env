# Shared Hadoop configuration for Lab 5 — WebHDFS REST + quotas + trash.

# --- core-site.xml ---
CORE_CONF_fs_defaultFS=hdfs://namenode:9000
CORE_CONF_hadoop_http_staticuser_user=root
# Enable the Trash: `hdfs dfs -rm` moves files to .Trash instead of deleting them.
# 60 = keep deleted files for 60 minutes before permanent removal.
CORE_CONF_fs_trash_interval=60

# --- hdfs-site.xml ---
HDFS_CONF_dfs_replication=1
HDFS_CONF_dfs_permissions_enabled=false
HDFS_CONF_dfs_namenode_datanode_registration_ip___hostname___check=false
# WebHDFS exposes the filesystem over a plain HTTP REST API.
HDFS_CONF_dfs_webhdfs_enabled=true
